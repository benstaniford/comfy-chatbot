#!/usr/bin/env python3
"""archive-agent — a tiny privileged host helper for comfy-chatbot.

The comfy-chatbot container runs unprivileged and cannot mount encrypted
volumes, so it asks this agent (running as root) to do the privileged
zuluCrypt-cli mount/unmount over a Unix domain socket. One newline-delimited
JSON request per connection, one JSON reply.

Requests:
  {"action": "mount",        "volume": "<host path>", "password": "<passphrase>"}
  {"action": "unmount",      "volume": "<host path>"}
  {"action": "host-mount",   "volume": "<host path>", "password": "<passphrase>"}
  {"action": "host-unmount", "volume": "<host path>"}
  {"action": "fsck",         "volume": "<host path>", "password": "<passphrase>"}
  {"action": "status",       "volume": "<host path>"}
  {"action": "add-key",      "volume": "<host path>", "password": "<old>", "new_password": "<new>"}
  {"action": "remove-key",   "volume": "<host path>", "password": "<remove>", "keep_password": "<keep>"}
  {"action": "header-backup","volume": "<host path>"}

add-key/remove-key/header-backup re-key a volume by editing only its LUKS header (a
few KB), so they work while the volume is mounted and never touch the master key or
the data. add-key adds a new keyslot (authenticated by the existing passphrase) and
verifies the new one opens; remove-key drops a keyslot but refuses unless the key it
must keep still opens the volume first (never leave a volume with no working key).
header-backup writes the LUKS header to HEADER_BACKUP_DIR (0600) as a rollback before
the first re-key. Together they support making the volume passphrase depend on the
user's login password (see the app's /api/change-password re-key flow) so a leaked
compose SECRET_KEY alone can no longer decrypt the volumes.

mount/unmount/fsck take an optional "target": "archive" (default) or "output". The
output target is a second, persistently mounted volume the container uses for its
live image output; it has its own mount name + dir (see OUTPUT_MOUNT_* config) so
it never collides with the on-demand archive mount. A mount request may also pass
"create": true (+ optional "size", e.g. "20G") to auto-provision the volume on
first deploy if its file does not yet exist.

host-mount/host-unmount expose the archive volume at HOST_MOUNT_DIR for external
host tools (e.g. samba). They reuse the single archive zulu mount as a bind — never
a second decrypt — so the container stays the sole owner of the physical volume.
The container mediates them (see /api/host-mount) so they never race an archive or
fsck op. status reports mount state ({"open", "host_mounted", "archive_bound"}) so
the container can gate those ops without tracking state that would drift across its
own restarts.

A fsck request runs `e2fsck -f -y` on the volume's ext4 filesystem, opened via
cryptsetup WITHOUT mounting (e2fsck refuses a mounted fs). It auto-repairs any
corruption found (-y answers yes to every fix) and reports the outcome. The
volume must be unmounted; a mounted volume is refused. Used at container startup
to check the output volume before it is mounted, and on demand for the archive
volume (which is normally unmounted).

Replies:
  {"ok": true,  "mountpoint": "<dir>"}        # mount
  {"ok": true}                                # unmount / status
  {"ok": true,  "clean": bool, "corrected": bool, "uncorrected": bool,
   "exit_code": int, "output": "<e2fsck output>"}   # fsck
  {"ok": false, "error": "<message>"}

The password is supplied per request and is NEVER stored. It is handed to
zuluCrypt-cli via a 0600 key file in tmpfs (not on argv, so it never appears in
`ps`), which is deleted immediately after the mount attempt.

Config is read from /etc/archive-agent.conf (KEY=VALUE lines):
  SOCKET_PATH   default /run/archive-agent.sock
  SOCKET_MODE   default 0666   (octal; the container user must be able to connect)
  MOUNT_DIR     default /var/lib/archive-agent/mnt
  OUTPUT_MOUNT_DIR   default /var/lib/archive-agent/output
  OUTPUT_MOUNT_NAME  default comfy-output
"""

import os
import pwd
import sys
import json
import time
import socket
import logging
import tempfile
import subprocess
from pathlib import Path

CONFIG_PATH = os.environ.get("CONFIG_PATH", "/etc/archive-agent.conf")

DEFAULTS = {
    "SOCKET_PATH": "/run/archive-agent.sock",
    "SOCKET_MODE": "0666",
    "MOUNT_DIR": "/var/lib/archive-agent/mnt",
    # zuluCrypt-cli's -m is a path *component* appended to /run/media/private/$USER,
    # not an absolute path, so we mount under this name and then bind it onto
    # MOUNT_DIR (which propagates into the container).
    "MOUNT_NAME": "comfy-archive",
    # The live-output volume: a second, persistently mounted volume with its own
    # mount name + dir so it never collides with the on-demand archive mount.
    "OUTPUT_MOUNT_DIR": "/var/lib/archive-agent/output",
    "OUTPUT_MOUNT_NAME": "comfy-output",
    # Host-facing bind for the archive volume: where external host tools (samba)
    # see the decrypted archive when the container exposes it (the {"target":
    # "host"} mount). Same zulu mount as the archive — a bind, never a second
    # decrypt. Server-owned so the API can't bind decrypted data to an arbitrary
    # path. HOST_MOUNT_USER owns the mount root so that user can manage it directly.
    "HOST_MOUNT_DIR": "/run/media/private/ben/secure",
    "HOST_MOUNT_USER": "ben",
    # Where LUKS header backups are written before a re-key (add-key). Sensitive: a
    # header backup + a known passphrase can decrypt the volume, so keep it 0700 and
    # off any shared/exported path.
    "HEADER_BACKUP_DIR": "/var/lib/archive-agent/header-backups",
}

log = logging.getLogger("archive-agent")

# Marker file written at the volume root on mount; the container verifies it
# exists before deleting any originals. Keep in sync with app.py ARCHIVE_MARKER.
MARKER_NAME = ".comfy-archive"

# Upper bound for a single e2fsck run (the fsck action). A dirty 20G ext4 volume
# checks+repairs in well under a minute on a Pi 5; 15 min is a generous ceiling.
# The client side (app.py FSCK_TIMEOUT / agent_client) must wait LONGER than this
# so the agent returns its result before the client's socket read gives up.
E2FSCK_TIMEOUT_SECONDS = 900


def load_config():
    cfg = dict(DEFAULTS)
    try:
        with open(CONFIG_PATH, "r", encoding="utf-8") as fh:
            for line in fh:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, val = line.partition("=")
                cfg[key.strip()] = val.strip()
    except FileNotFoundError:
        log.warning("config %s not found; using defaults", CONFIG_PATH)
    return cfg


def _run(cmd, key_input=None):
    """Run a command, optionally writing `key_input` to a 0600 tmpfs key file
    passed via -f. Returns (returncode, combined_output)."""
    keyfile = None
    try:
        if key_input is not None:
            fd, keyfile = tempfile.mkstemp(prefix="caa-", dir="/dev/shm")
            os.fchmod(fd, 0o600)
            # No trailing newline: zuluCrypt-cli uses the file content verbatim.
            os.write(fd, key_input.encode("utf-8"))
            os.close(fd)
            cmd = cmd + ["-f", keyfile]
        proc = subprocess.run(
            cmd, capture_output=True, text=True, check=False, timeout=120,
        )
        return proc.returncode, (proc.stdout + proc.stderr).strip()
    finally:
        if keyfile and os.path.exists(keyfile):
            os.remove(keyfile)


def _zulu_mountpoint(name):
    """zuluCrypt-cli mounts at /run/media/private/<user>/<name> (the -m value is a
    component appended to that prefix, not an absolute path)."""
    user = pwd.getpwuid(os.geteuid()).pw_name
    return f"/run/media/private/{user}/{name}"


def _volume_in_use(volume):
    """True if the backing file `volume` is attached to any loop device — i.e. it
    is currently decrypted/mounted somewhere (the archive bind, the host bind, or a
    stray mapper). Used to gate fsck (e2fsck must run on an unmounted fs) and to
    report status. Catches uses the agent's own mountpoint checks can't see."""
    if not volume:
        return False
    rc, out = _run(["losetup", "-j", volume])
    return rc == 0 and bool(out.strip())


def _ensure_bind(src, mount_dir, volume, rollback):
    """Bind the decrypted filesystem at `src` onto `mount_dir` and make its root
    writable for the unprivileged container user. Idempotent: if `mount_dir`
    already resolves to the same filesystem as `src` the bind is left as-is (so
    we never stack a second bind that a single unmount couldn't pop). Returns
    None on success or an error dict. If the bind fails and `rollback` is set
    (we opened the volume this call), the volume is closed again.

    MOUNT_DIR is a shared mount (see setup_shared_mount), so this bind
    propagates into the container.
    """
    try:
        already_bound = os.stat(mount_dir).st_dev == os.stat(src).st_dev
    except OSError:
        already_bound = False
    if not already_bound:
        try:
            subprocess.run(["mount", "--bind", src, mount_dir],
                           check=True, capture_output=True, text=True)
        except subprocess.CalledProcessError as exc:
            if rollback:
                _run(["zuluCrypt-cli", "-q", "-d", volume])  # roll back the open
            return {"ok": False, "error": f"bind to {mount_dir} failed: {exc.stderr.strip()}"}

    # The mounted filesystem's root is owned by root; the container writes as an
    # unprivileged user, so make the mount root world-writable (this is a
    # private encrypted archive). Persisted in the volume, applied each mount.
    try:
        os.chmod(mount_dir, 0o777)
    except OSError as exc:
        log.warning("could not chmod %s: %s", mount_dir, exc)

    # Drop a marker file at the volume root. The container checks for this before
    # copying+deleting: if MOUNT_DIR and the container's bind source disagree (or
    # the mount didn't propagate), the container sees a plain directory with no
    # marker and aborts rather than silently writing to unencrypted disk.
    try:
        (Path(mount_dir) / MARKER_NAME).write_text("comfy-archive\n", encoding="utf-8")
    except OSError as exc:
        log.warning("could not write marker in %s: %s", mount_dir, exc)
    return None


def _resolve_target(cfg, req):
    """Map a request's logical target to its (mount name, host mount dir) pair.
    'output' is the persistent live-output volume; 'host' exposes the archive
    volume at the host-facing directory (same zulu mount as the archive, different
    bind target); anything else is the archive."""
    target = req.get("target")
    if target == "output":
        return cfg["OUTPUT_MOUNT_NAME"], cfg["OUTPUT_MOUNT_DIR"]
    if target == "host":
        return cfg["MOUNT_NAME"], cfg["HOST_MOUNT_DIR"]
    return cfg["MOUNT_NAME"], cfg["MOUNT_DIR"]


def _parse_size(size):
    """Parse a human size ('20G', '500M', '20GB', '1048576') into a byte count.
    Returns None if it can't be parsed. Used to size the output volume's backing
    file on first deploy."""
    s = str(size).strip().upper().rstrip("B")
    units = {"K": 1024, "M": 1024 ** 2, "G": 1024 ** 3, "T": 1024 ** 4}
    try:
        if s and s[-1] in units:
            return int(float(s[:-1]) * units[s[-1]])
        return int(s)
    except ValueError:
        return None


def _write_keyfile(password):
    """Write `password` to a fresh 0600 tmpfs key file and return its path. Keeps
    the passphrase off argv (so it never appears in `ps`). Caller must remove it."""
    fd, keyfile = tempfile.mkstemp(prefix="caa-", dir="/dev/shm")
    os.fchmod(fd, 0o600)
    # No trailing newline: the passphrase is used verbatim.
    os.write(fd, password.encode("utf-8"))
    os.close(fd)
    return keyfile


def _cryptsetup_format(volume, password):
    """luksFormat `volume` with `password`. Returns None on success or an error
    string. Passphrase via 0600 tmpfs keyfile."""
    keyfile = None
    try:
        keyfile = _write_keyfile(password)
        proc = subprocess.run(
            ["cryptsetup", "luksFormat", "--batch-mode", "--key-file", keyfile, volume],
            capture_output=True, text=True, timeout=300,
        )
        if proc.returncode != 0:
            return f"cryptsetup luksFormat failed: {(proc.stdout + proc.stderr).strip()}"
        return None
    finally:
        if keyfile and os.path.exists(keyfile):
            os.remove(keyfile)


def _cryptsetup_open(volume, password, mapper):
    """Open LUKS `volume` at /dev/mapper/`mapper` WITHOUT mounting it — the
    decrypted block device for operations that don't want a mounted filesystem
    (volume creation's mkfs, and fsck). Returns None on success or an error
    string. Passphrase via 0600 tmpfs keyfile."""
    keyfile = None
    try:
        keyfile = _write_keyfile(password)
        proc = subprocess.run(
            ["cryptsetup", "open", "--key-file", keyfile, volume, mapper],
            capture_output=True, text=True, timeout=300,
        )
        if proc.returncode != 0:
            return f"cryptsetup open failed: {(proc.stdout + proc.stderr).strip()}"
        return None
    finally:
        if keyfile and os.path.exists(keyfile):
            os.remove(keyfile)


def _cryptsetup_close(mapper):
    """Close the /dev/mapper/`mapper` device. Harmless (and quiet) if not open."""
    subprocess.run(["cryptsetup", "close", mapper], capture_output=True, text=True)


def _cryptsetup_test_passphrase(volume, password):
    """True if `password` opens LUKS `volume`. Uses --test-passphrase, which
    verifies a keyslot WITHOUT creating a mapper or mounting anything, so it is safe
    to call on a volume that is currently mounted. Passphrase via 0600 tmpfs keyfile."""
    keyfile = None
    try:
        keyfile = _write_keyfile(password)
        proc = subprocess.run(
            ["cryptsetup", "open", "--test-passphrase", "--key-file", keyfile, volume],
            capture_output=True, text=True, timeout=120,
        )
        return proc.returncode == 0
    finally:
        if keyfile and os.path.exists(keyfile):
            os.remove(keyfile)


def handle_add_key(cfg, req):
    """Add a new LUKS keyslot to `volume`, authenticated by the existing passphrase.

    Keyslot-only (header edit), so it is safe while the volume is mounted. Idempotent:
    if `new_password` already opens the volume (a retry after a partial run), it is a
    no-op success — we don't burn a fresh keyslot each attempt. Verifies the new key
    actually opens the volume before reporting success."""
    volume = req.get("volume")
    old = req.get("password")
    new = req.get("new_password")
    if not volume or old is None or new is None:
        return {"ok": False, "error": "add-key requires 'volume', 'password', 'new_password'"}
    if not os.path.exists(volume):
        return {"ok": False, "error": f"volume {volume} does not exist"}

    if _cryptsetup_test_passphrase(volume, new):
        return {"ok": True, "added": False}

    oldkf = newkf = None
    try:
        oldkf = _write_keyfile(old)
        newkf = _write_keyfile(new)
        proc = subprocess.run(
            ["cryptsetup", "luksAddKey", "--key-file", oldkf, volume, newkf],
            capture_output=True, text=True, timeout=120,
        )
        if proc.returncode != 0:
            return {"ok": False,
                    "error": f"luksAddKey failed: {(proc.stdout + proc.stderr).strip()}"}
    finally:
        for kf in (oldkf, newkf):
            if kf and os.path.exists(kf):
                os.remove(kf)

    if not _cryptsetup_test_passphrase(volume, new):
        return {"ok": False,
                "error": "luksAddKey reported success but the new passphrase does "
                         "not open the volume"}
    log.info("add-key: added a keyslot to %s", volume)
    return {"ok": True, "added": True}


def handle_remove_key(cfg, req):
    """Remove a LUKS keyslot from `volume`, but never leave it without a working key.

    Requires `keep_password` to open the volume first (safety), and refuses to remove
    the very key it must keep. Idempotent: if `password` (the key to remove) no longer
    opens the volume, it is already gone → no-op success."""
    volume = req.get("volume")
    remove = req.get("password")
    keep = req.get("keep_password")
    if not volume or remove is None or keep is None:
        return {"ok": False,
                "error": "remove-key requires 'volume', 'password', 'keep_password'"}
    if not os.path.exists(volume):
        return {"ok": False, "error": f"volume {volume} does not exist"}
    if remove == keep:
        return {"ok": False, "error": "refusing to remove the key that must be kept"}

    # Never leave the volume with no working key.
    if not _cryptsetup_test_passphrase(volume, keep):
        return {"ok": False,
                "error": "keep_password does not open the volume; refusing to remove any key"}
    # Already gone → nothing to do.
    if not _cryptsetup_test_passphrase(volume, remove):
        return {"ok": True, "removed": False}

    removekf = None
    try:
        removekf = _write_keyfile(remove)
        proc = subprocess.run(
            ["cryptsetup", "luksRemoveKey", volume, removekf],
            capture_output=True, text=True, timeout=120,
        )
        if proc.returncode != 0:
            return {"ok": False,
                    "error": f"luksRemoveKey failed: {(proc.stdout + proc.stderr).strip()}"}
    finally:
        if removekf and os.path.exists(removekf):
            os.remove(removekf)

    if not _cryptsetup_test_passphrase(volume, keep):
        return {"ok": False,
                "error": "keep_password no longer opens the volume after removal"}
    log.info("remove-key: removed a keyslot from %s", volume)
    return {"ok": True, "removed": True}


def handle_header_backup(cfg, req):
    """Back up the LUKS header of `volume` to HEADER_BACKUP_DIR (0600) as the
    rollback for a corrupted-header risk during a re-key. Sensitive — see the config
    comment. Each backup gets a unique timestamped name (luksHeaderBackup refuses to
    overwrite)."""
    volume = req.get("volume")
    if not volume:
        return {"ok": False, "error": "header-backup requires 'volume'"}
    if not os.path.exists(volume):
        return {"ok": False, "error": f"volume {volume} does not exist"}

    backup_dir = cfg.get("HEADER_BACKUP_DIR", DEFAULTS["HEADER_BACKUP_DIR"])
    try:
        os.makedirs(backup_dir, exist_ok=True)
        os.chmod(backup_dir, 0o700)
    except OSError as exc:
        return {"ok": False, "error": f"could not prepare {backup_dir}: {exc}"}

    ts = time.strftime("%Y%m%d-%H%M%S")
    base = os.path.basename(volume) or "volume"
    path = os.path.join(backup_dir, f"{base}-{ts}.img")
    n = 0
    while os.path.exists(path):  # same-second collision guard
        n += 1
        path = os.path.join(backup_dir, f"{base}-{ts}-{n}.img")

    proc = subprocess.run(
        ["cryptsetup", "luksHeaderBackup", volume, "--header-backup-file", path],
        capture_output=True, text=True, timeout=120,
    )
    if proc.returncode != 0:
        return {"ok": False,
                "error": f"luksHeaderBackup failed: {(proc.stdout + proc.stderr).strip()}"}
    try:
        os.chmod(path, 0o600)
    except OSError:
        pass
    log.info("header-backup: %s -> %s", volume, path)
    return {"ok": True, "backup": path}


def _create_volume(volume, size, password):
    """Auto-provision a new LUKS volume file at `volume` of `size` with an ext4
    filesystem inside (first-deploy path for the output volume). Uses cryptsetup
    + mkfs directly — deterministic and non-interactive — so zuluCrypt-cli -o can
    then open+mount it like any other LUKS volume. The passphrase is written to a
    0600 tmpfs key file (never on argv). Returns None on success or an error
    string; on failure the half-written volume file is removed so a retry starts
    clean. cryptsetup is a zulucrypt-cli dependency, so it is always present."""
    parent = os.path.dirname(volume) or "/"
    try:
        os.makedirs(parent, exist_ok=True)
    except OSError as exc:
        return f"could not create {parent}: {exc}"

    nbytes = _parse_size(size)
    if nbytes is None:
        return f"invalid volume size: {size!r}"

    mapper = f"comfy-output-init-{os.getpid()}"
    err = None
    try:
        with open(volume, "xb") as fh:   # x: never clobber an existing file
            fh.truncate(nbytes)
        err = _cryptsetup_format(volume, password)
        if err is None:
            err = _cryptsetup_open(volume, password, mapper)
        if err is None:
            proc = subprocess.run(["mkfs.ext4", "-q", f"/dev/mapper/{mapper}"],
                                  capture_output=True, text=True, timeout=300)
            if proc.returncode != 0:
                err = f"mkfs.ext4 failed: {(proc.stdout + proc.stderr).strip()}"
    except OSError as exc:
        err = f"could not create volume file: {exc}"
    finally:
        _cryptsetup_close(mapper)  # harmless if the open never succeeded

    if err is not None:
        if os.path.exists(volume):
            try:
                os.remove(volume)
            except OSError:
                pass
        return err
    log.info("created encrypted volume %s (%s)", volume, size)
    return None


def interpret_e2fsck(rc, output=""):
    """Map an e2fsck exit code (a bitmask) to a structured result dict.

    e2fsck exit bits: 1 = filesystem errors corrected, 2 = errors corrected +
    reboot advised (irrelevant here), 4 = errors left UNcorrected, 8 = operational
    error, 16 = usage/syntax error, 32 = cancelled, 128 = shared-lib error. 0 = the
    filesystem was already clean. Bits 1+2 mean e2fsck ran and fixed things; bit 4
    means it ran but couldn't fix everything; bits >=8 mean e2fsck itself failed.
    """
    operational = bool(rc & ~7)  # any bit above 4 -> e2fsck itself failed
    result = {
        "exit_code": rc,
        "clean": rc == 0,
        "corrected": bool(rc & 3),
        "uncorrected": bool(rc & 4),
        "output": output,
    }
    if operational:
        result["ok"] = False
        result["error"] = f"e2fsck operational error (exit {rc})"
    else:
        result["ok"] = True
    return result


def handle_fsck(cfg, req):
    """Check (and auto-repair) a volume's ext4 filesystem with e2fsck. The volume
    is opened via cryptsetup WITHOUT mounting — e2fsck refuses a mounted fs, and
    opening a second dm-crypt mapper over a mounted rw volume would corrupt it."""
    volume = req.get("volume")
    password = req.get("password")
    if not volume or password is None:
        return {"ok": False, "error": "fsck requires 'volume' and 'password'"}

    # First-deploy: the output volume may not exist yet (it's created on first
    # mount). Nothing to check — report a skip, not an error, so the startup
    # check is a no-op before the volume has ever been provisioned.
    if not os.path.exists(volume):
        return {"ok": True, "skipped": "volume absent",
                "clean": True, "corrected": False, "uncorrected": False}

    name, mount_dir = _resolve_target(cfg, req)

    # Refuse if the volume looks mounted (zuluCrypt's own mountpoint or our bind
    # dir). e2fsck must run unmounted; a live rw mount + a second mapper = data
    # loss. The output volume is only fsck'd at startup before it's mounted; the
    # archive volume is checked under the app's archive_lock while unmounted.
    if os.path.ismount(_zulu_mountpoint(name)) or os.path.ismount(mount_dir):
        return {"ok": False, "error": "volume is mounted; unmount before fsck"}
    # Belt-and-suspenders: refuse if the backing file is decrypted/attached at all
    # (e.g. exposed via the host bind under a different mountpoint the checks above
    # can't see). This closes the historic data-loss path where a second mapper was
    # opened over a filesystem another tool had mounted read-write.
    if _volume_in_use(volume):
        return {"ok": False, "error": "volume is open/in use elsewhere; unmount before fsck"}

    mapper = f"comfy-fsck-{os.getpid()}"
    err = _cryptsetup_open(volume, password, mapper)
    if err is not None:
        return {"ok": False, "error": err}
    try:
        # -f: force a full check even if the fs is flagged clean. -y: assume "yes"
        # to every repair (unattended auto-fix — thorough, but can discard
        # unrecoverable data on severe corruption).
        proc = subprocess.run(
            ["e2fsck", "-f", "-y", f"/dev/mapper/{mapper}"],
            capture_output=True, text=True, timeout=E2FSCK_TIMEOUT_SECONDS,
        )
        rc, out = proc.returncode, (proc.stdout + proc.stderr).strip()
    except subprocess.TimeoutExpired:
        return {"ok": False,
                "error": f"e2fsck timed out after {E2FSCK_TIMEOUT_SECONDS}s"}
    finally:
        _cryptsetup_close(mapper)

    result = interpret_e2fsck(rc, out[-4000:])  # cap the echoed output
    if result["clean"]:
        log.info("fsck %s: clean", volume)
    elif not result["ok"] or result["uncorrected"]:
        log.error("fsck %s: rc=%s (problems remain): %s", volume, rc, out)
    else:
        log.warning("fsck %s: rc=%s (errors corrected)", volume, rc)
    return result


def _open_volume(name, volume, password):
    """Ensure the LUKS `volume` is decrypted and mounted at its zulu mountpoint
    (/run/media/private/<user>/<name>), reusing an existing open if one is up.
    Returns (src, opened_now, err): on failure err is an error dict the caller
    should return; otherwise err is None and `src` is the decrypted mountpoint."""
    src = _zulu_mountpoint(name)

    # zuluCrypt-cli open, read-write (default is ro). Format (LUKS/VeraCrypt/PLAIN)
    # is auto-detected. The passphrase is passed via -f keyfile (see _run) so it
    # never appears on argv.
    cmd = ["zuluCrypt-cli", "-o", "-d", volume, "-m", name, "-e", "rw"]
    rc, out = _run(cmd, key_input=password)

    opened_now = rc == 0
    if not opened_now:
        # `-o` fails if the volume is already open — either a leftover mount from a
        # killed run, or the same single archive mount already exposed under
        # another bind. That's recoverable: if the decrypted filesystem is already
        # mounted at `src`, treat the open as idempotent so the caller just
        # (re)establishes its bind. Any other failure (e.g. wrong password) leaves
        # nothing mounted at `src`.
        if os.path.ismount(src):
            log.warning("volume already open (rc=%s: %s); recovering existing mount",
                        rc, out)
        else:
            log.error("open failed (rc=%s): %s", rc, out)
            return src, False, {"ok": False, "error": f"zuluCrypt-cli open failed: {out}"}
    elif not os.path.ismount(src):
        log.error("expected mount %s not found after open", src)
        return src, True, {"ok": False, "error": f"volume opened but {src} is not mounted"}
    return src, opened_now, None


def _mount_target(cfg, req):
    """Shared body for mount and host-mount: resolve the target, auto-provision if
    asked, open the volume (once) and bind it onto the target dir. Returns
    (mount_dir, opened_now, err); err is an error dict on failure else None."""
    volume = req.get("volume")
    password = req.get("password")
    if not volume or password is None:
        return None, False, {"ok": False, "error": "mount requires 'volume' and 'password'"}

    name, mount_dir = _resolve_target(cfg, req)
    Path(mount_dir).mkdir(parents=True, exist_ok=True)

    # First-deploy auto-provisioning: create the volume if asked and it's absent.
    if req.get("create") and not os.path.exists(volume):
        err = _create_volume(volume, req.get("size") or "20G", password)
        if err is not None:
            return mount_dir, False, {"ok": False, "error": err}

    src, opened_now, err = _open_volume(name, volume, password)
    if err is not None:
        return mount_dir, opened_now, err

    err = _ensure_bind(src, mount_dir, volume, rollback=opened_now)
    if err is not None:
        return mount_dir, opened_now, err

    log.info("mounted %s -> %s -> %s", volume, src, mount_dir)
    return mount_dir, opened_now, None


def handle_mount(cfg, req):
    mount_dir, _opened_now, err = _mount_target(cfg, req)
    if err is not None:
        return err
    return {"ok": True, "mountpoint": mount_dir}


def handle_host_mount(cfg, req):
    """Expose the archive volume at the host-facing directory (HOST_MOUNT_DIR) for
    external host tools (e.g. samba). Reuses the single archive zulu mount — never
    a second decrypt — and binds it to the host dir, then hands the mount root to
    HOST_MOUNT_USER so that user can manage files directly. The container mediates
    this (see /api/host-mount) so it never races an archive/fsck op."""
    req = dict(req, target="host")
    mount_dir, _opened_now, err = _mount_target(cfg, req)
    if err is not None:
        return err

    # 0777 (set by _ensure_bind) already permits traversal; hand ownership of the
    # mount root to the configured host user too. Best-effort.
    user = cfg.get("HOST_MOUNT_USER")
    if user:
        try:
            pw = pwd.getpwnam(user)
            os.chown(mount_dir, pw.pw_uid, pw.pw_gid)
        except (KeyError, OSError) as exc:
            log.warning("could not chown %s to %s: %s", mount_dir, user, exc)

    # Make the whole archive recursively accessible to host tools (samba, and the
    # host user editing files directly). Files written by the container are owned
    # by its uid, so without this the host user couldn't rewrite them. This
    # replaces the `sudo chmod -R a+rwx` the old `m` script ran after mounting;
    # done here (as root) it keeps `m` unprivileged. Best-effort, and it skips
    # lost+found (owned by the filesystem).
    try:
        subprocess.run(
            ["chmod", "-R", "a+rwx", mount_dir],
            capture_output=True, text=True, timeout=120,
        )
    except (subprocess.SubprocessError, OSError) as exc:
        log.warning("could not chmod -R %s: %s", mount_dir, exc)

    return {"ok": True, "mountpoint": mount_dir}


def handle_unmount(cfg, req):
    volume = req.get("volume")
    if not volume:
        return {"ok": False, "error": "unmount requires 'volume'"}
    _, mount_dir = _resolve_target(cfg, req)
    # Detach the volume bind(s) so zuluCrypt can unmount its own mountpoint. A
    # killed run can leave binds stacked on mount_dir; a single umount would pop
    # only one, leaving the decrypted fs busy so the close below fails and the
    # volume stays "open" forever. Pop every bind whose device is the volume's,
    # stopping at the shared self-bind anchor (same device as mount_dir's parent,
    # see setup_shared_mount) so propagation into the container survives.
    anchor_dev = os.stat(os.path.dirname(mount_dir) or "/").st_dev
    for _ in range(16):
        if not os.path.ismount(mount_dir) or os.stat(mount_dir).st_dev == anchor_dev:
            break
        if subprocess.run(["umount", mount_dir],
                          capture_output=True, text=True).returncode != 0:
            break
    rc, out = _run(["zuluCrypt-cli", "-q", "-d", volume])
    if rc != 0:
        log.error("close failed (rc=%s): %s", rc, out)
        return {"ok": False, "error": f"zuluCrypt-cli close failed: {out}"}
    log.info("unmounted %s", volume)
    return {"ok": True}


def handle_host_unmount(cfg, req):
    """Tear down the host-facing bind (HOST_MOUNT_DIR) and close the archive volume
    so it returns to the unmounted-at-rest state (so /fscheck works again). Same
    mechanics as unmount, keyed to the 'host' target."""
    return handle_unmount(cfg, dict(req, target="host"))


def handle_status(cfg, req):
    """Report mount state so the container can gate archive/fsck ops (see
    /api/host-status) without tracking state itself — which would drift across
    container restarts, since the mounts live in the host namespace. `open`
    reflects whether the backing file is currently decrypted/in use anywhere."""
    host_mount_dir = cfg.get("HOST_MOUNT_DIR", "")
    return {
        "ok": True,
        "open": _volume_in_use(req.get("volume")),
        "host_mounted": bool(host_mount_dir) and os.path.ismount(host_mount_dir),
        "archive_bound": os.path.ismount(cfg["MOUNT_DIR"]),
    }


def handle(cfg, req):
    action = req.get("action")
    if action == "mount":
        return handle_mount(cfg, req)
    if action == "unmount":
        return handle_unmount(cfg, req)
    if action == "host-mount":
        return handle_host_mount(cfg, req)
    if action == "host-unmount":
        return handle_host_unmount(cfg, req)
    if action == "fsck":
        return handle_fsck(cfg, req)
    if action == "status":
        return handle_status(cfg, req)
    if action == "add-key":
        return handle_add_key(cfg, req)
    if action == "remove-key":
        return handle_remove_key(cfg, req)
    if action == "header-backup":
        return handle_header_backup(cfg, req)
    return {"ok": False, "error": f"unknown action: {action!r}"}


def read_request(conn):
    chunks = []
    while True:
        data = conn.recv(4096)
        if not data:
            break
        chunks.append(data)
        if b"\n" in data:
            break
    raw = b"".join(chunks).decode("utf-8").strip()
    return json.loads(raw) if raw else {}


def setup_shared_mount(mount_dir):
    """Ensure MOUNT_DIR is a shared mount so a volume mounted here propagates
    into the container's rshared bind mount. Bind it to itself if it isn't
    already a mount point, then mark it shared (idempotent)."""
    Path(mount_dir).mkdir(parents=True, exist_ok=True)
    try:
        if not os.path.ismount(mount_dir):
            subprocess.run(["mount", "--bind", mount_dir, mount_dir],
                           check=True, capture_output=True, text=True)
        subprocess.run(["mount", "--make-shared", mount_dir],
                       check=True, capture_output=True, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        log.warning("could not make %s a shared mount: %s", mount_dir, exc)


def serve(cfg):
    setup_shared_mount(cfg["MOUNT_DIR"])
    setup_shared_mount(cfg["OUTPUT_MOUNT_DIR"])
    sock_path = cfg["SOCKET_PATH"]
    if os.path.exists(sock_path):
        os.remove(sock_path)
    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(sock_path)
    os.chmod(sock_path, int(cfg["SOCKET_MODE"], 8))
    srv.listen(8)
    log.info("listening on %s (mount dir %s)", sock_path, cfg["MOUNT_DIR"])
    while True:
        conn, _ = srv.accept()
        try:
            conn.settimeout(120)
            try:
                req = read_request(conn)
                resp = handle(cfg, req)
            except json.JSONDecodeError as exc:
                resp = {"ok": False, "error": f"invalid JSON: {exc}"}
            except Exception as exc:  # never let one request kill the agent
                log.exception("request failed")
                resp = {"ok": False, "error": str(exc)}
            conn.sendall((json.dumps(resp) + "\n").encode("utf-8"))
        finally:
            conn.close()


def main():
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
        stream=sys.stderr,
    )
    if os.geteuid() != 0:
        log.warning("not running as root; zuluCrypt-cli mounts will likely fail")
    cfg = load_config()
    try:
        serve(cfg)
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
